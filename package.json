{
  "name": "delivery-tracking-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "node ace test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#tests/*": "./tests/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js",
    "#rules/*": "./app/rules/*.js",
    "#helpers/*": "./app/helpers/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/assert": "^4.2.0",
    "@japa/browser-client": "^2.3.0",
    "@japa/plugin-adonisjs": "^5.1.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/alpinejs": "^3.13.11",
    "@types/luxon": "^3.7.1",
    "@types/node": "~24.11.0",
    "@types/qrcode": "^1.5.6",
    "alpinejs": "^3.15.8",
    "eslint": "^10.0.2",
    "hot-hook": "^1.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "youch": "^4.1.0"
  },
  "dependencies": {
    "@adonisjs/auth": "^10.0.0",
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/lucid": "^22.0.0",
    "@adonisjs/mail": "^10.1.0",
    "@adonisjs/session": "^8.0.0",
    "@adonisjs/shield": "^9.0.0",
    "@adonisjs/static": "^2.0.0",
    "@adonisjs/vite": "^5.1.0",
    "@fontsource-variable/outfit": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@vinejs/vine": "^4.3.0",
    "better-sqlite3": "^12.6.2",
    "edge.js": "^6.5.0",
    "intl-tel-input": "^26.8.1",
    "libphonenumber-js": "^1.12.40",
    "luxon": "^3.7.2",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.4",
    "tailwindcss": "^4.2.2"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
