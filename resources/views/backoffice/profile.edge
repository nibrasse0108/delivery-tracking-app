        <form method="POST" action="{{ route('backoffice.profile.update_info') }}" class="p-6">
            {{ csrfField() }}
            <div class="space-y-5">

                {{-- Avatar --}}
                <div class="flex items-center gap-4">
                    <div class="inline-flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-brand-500 text-xl font-bold text-white">
                        {{ auth.user.initials }}
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-800 dark:text-white/90">{{ auth.user.fullName ?? auth.user.email }}</p>
                        <p class="text-xs text-gray-400 dark:text-gray-500">
                            {{ auth.user.role === 'super_admin' ? 'Super Administrateur' : 'Administrateur' }}
                        </p>
                    </div>
                </div>

                <div class="grid gap-4 sm:grid-cols-2">
                    {{-- Nom complet --}}
                    <div>
                        <label for="fullName" class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">
                            Nom complet
                        </label>
                        <input
                            type="text"
                            id="fullName"
                            name="fullName"
                            value="{{ flashMessages.get('fullName') ?? auth.user.fullName ?? '' }}"
                            placeholder="Prénom Nom"
                            class="shadow-theme-xs focus:border-brand-300 focus:ring-brand-500/10 dark:focus:border-brand-800 h-11 w-full rounded-lg border bg-transparent px-4 py-2.5 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-3 focus:outline-hidden dark:text-white/90 dark:placeholder:text-white/30 {{ flashMessages.has('errors.fullName') ? 'border-red-400 dark:border-red-600' : 'border-gray-300 dark:border-gray-700 dark:bg-gray-900' }}">
                        @if(flashMessages.has('errors.fullName'))
                            <p class="mt-1 text-xs text-red-500">{{ flashMessages.get('errors.fullName') }}</p>
                        @end
                    </div>

                    {{-- Téléphone --}}
                    <div>
                        <label for="phone" class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">
                            Téléphone
                        </label>
                        <input
                            type="tel"
                            id="phone"
                            name="phone"
                            value="{{ flashMessages.get('phone') ?? auth.user.phone ?? '' }}"
                            placeholder="+269 3XX XX XX"
                            class="shadow-theme-xs focus:border-brand-300 focus:ring-brand-500/10 dark:focus:border-brand-800 h-11 w-full rounded-lg border bg-transparent px-4 py-2.5 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-3 focus:outline-hidden dark:text-white/90 dark:placeholder:text-white/30 {{ flashMessages.has('errors.phone') ? 'border-red-400 dark:border-red-600' : 'border-gray-300 dark:border-gray-700 dark:bg-gray-900' }}">
