                            @if(!step.isLast)
                                <span class="absolute left-3.5 top-7 bottom-0 w-px {{ step.isDone ? 'bg-brand-300 dark:bg-brand-700' : 'bg-gray-200 dark:bg-gray-700' }}"></span>
                            @end
                            {{-- Icône --}}
                            <span class="relative z-10 flex h-7 w-7 shrink-0 items-center justify-center rounded-full
                                {{ step.isDone ? 'bg-brand-500' : '' }}
