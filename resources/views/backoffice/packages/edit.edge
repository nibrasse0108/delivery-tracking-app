            </div>

            {{-- Paiement --}}
            <div class="rounded-xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/3">
                <div class="border-b border-gray-200 px-6 py-4 dark:border-gray-800 flex items-center justify-between">
                    <h3 class="text-base font-semibold text-gray-800 dark:text-white/90">Paiement</h3>
                    @if(package.paymentStatus === 'paid')
                        <span class="inline-flex items-center gap-1.5 rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-700 dark:bg-green-900/30 dark:text-green-400">
                            <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
                            Payé
                        </span>
                    @else
                        <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-medium text-amber-700 dark:bg-amber-900/30 dark:text-amber-400">
                            <span class="h-1.5 w-1.5 rounded-full bg-amber-500"></span>
                            Non payé
                        </span>
                    @end
                </div>
                <div class="p-5 space-y-3">
                    @if(package.paymentStatus === 'paid')
                        <div class="space-y-2 text-sm">
                            <div class="flex justify-between">
                                <span class="text-gray-500 dark:text-gray-400">Méthode</span>
                                <span class="font-medium text-gray-700 dark:text-gray-300">
                                    {{ package.paymentMethod === 'cash' ? 'Espèces' : 'Mobile Money' }}
                                </span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-500 dark:text-gray-400">Date</span>
                                <span class="font-medium text-gray-700 dark:text-gray-300">
                                    {{ package.paidAt.setLocale('fr').toFormat("dd MMM yyyy 'à' HH'h'mm") }}
                                </span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-500 dark:text-gray-400">Montant</span>
                                <span class="font-semibold text-gray-800 dark:text-white/90">
                                    {{ (Number(package.price) + Number(package.extraFees ?? 0)).toLocaleString('fr-FR') }} KMF
                                </span>
                            </div>
                        </div>
                    @else
                        <form method="POST" action="{{ route('backoffice.packages.record_payment', { id: package.id }) }}" class="space-y-3">
                            {{ csrfField() }}
                            <div>
                                <label for="paymentMethod" class="mb-1.5 block text-xs font-medium text-gray-600 dark:text-gray-400">Méthode de paiement</label>
                                <select
                                    id="paymentMethod"
                                    name="paymentMethod"
                                    class="shadow-theme-xs h-10 w-full rounded-lg border border-gray-300 bg-transparent px-3 py-2 text-sm text-gray-800 focus:border-brand-300 focus:ring-3 focus:ring-brand-500/10 focus:outline-hidden dark:border-gray-700 dark:bg-gray-900 dark:text-white/90">
                                    <option value="cash">Espèces</option>
                                    <option value="mobile_money">Mobile Money</option>
                                </select>
                            </div>
                            <div class="flex items-center justify-between rounded-lg bg-gray-50 dark:bg-gray-800/50 px-3 py-2 text-xs">
                                <span class="text-gray-500">Total à encaisser</span>
                                <span class="font-bold text-gray-800 dark:text-white/90">{{ (Number(package.price) + Number(package.extraFees ?? 0)).toLocaleString('fr-FR') }} KMF</span>
                            </div>
                            <button type="submit"
                                class="w-full inline-flex items-center justify-center gap-2 rounded-lg bg-green-600 hover:bg-green-700 px-4 py-2.5 text-sm font-medium text-white transition-colors">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                                </svg>
                                Marquer comme payé
                            </button>
                        </form>
                    @end
                </div>
            </div>

            {{-- Photo du colis --}}
            <div class="rounded-xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/3">
                <div class="border-b border-gray-200 px-6 py-4 dark:border-gray-800">
                    <h3 class="text-base font-semibold text-gray-800 dark:text-white/90">Photo du colis</h3>
                </div>
                <div class="p-5">
                    @if(package.photoPath)
                        <img src="{{ package.photoPath }}" alt="Photo du colis {{ package.trackingNumber }}"
                            class="w-full rounded-lg border border-gray-200 dark:border-gray-700 object-cover max-h-52">
                        <form method="POST" action="{{ route('backoffice.packages.upload_photo', { id: package.id }) }}"
                            enctype="multipart/form-data" class="mt-3">
                            {{ csrfField() }}
                            <input type="file" name="photo" accept=".jpg,.jpeg,.png,.webp"
                                class="block w-full text-xs text-gray-700 dark:text-gray-400 file:mr-3 file:rounded-lg file:border-0 file:bg-brand-50 file:px-3 file:py-1.5 file:text-xs file:font-medium file:text-brand-700 hover:file:bg-brand-100 dark:file:bg-brand-900/30 dark:file:text-brand-400"
                                onchange="this.form.submit()">
                        </form>
                    @else
                        <form method="POST" action="{{ route('backoffice.packages.upload_photo', { id: package.id }) }}"
                            enctype="multipart/form-data">
                            {{ csrfField() }}
                            <div class="flex flex-col items-center justify-center rounded-lg border-2 border-dashed border-gray-300 dark:border-gray-700 py-8 text-center">
                                <svg class="mb-2 h-8 w-8 text-gray-300 dark:text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                                <p class="text-xs text-gray-400 mb-3">JPG, PNG, WEBP — max 5 Mo</p>
                                <input type="file" name="photo" accept=".jpg,.jpeg,.png,.webp"
                                    class="block w-full text-xs text-gray-700 dark:text-gray-400 file:mr-3 file:rounded-lg file:border-0 file:bg-brand-50 file:px-3 file:py-1.5 file:text-xs file:font-medium file:text-brand-700 hover:file:bg-brand-100 dark:file:bg-brand-900/30 dark:file:text-brand-400"
                                    onchange="this.form.submit()">
                            </div>
                        </form>
                    @end
                </div>
            </div>

            {{-- Reçu --}}
            <a href="/suivi/{{ package.receiptToken }}" target="_blank"
                class="flex items-center gap-3 rounded-xl border border-gray-200 bg-white px-5 py-4 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-800 dark:bg-white/3 dark:text-gray-300 dark:hover:bg-white/5 transition-colors">
                <svg class="w-4 h-4 shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
                </svg>
                Consulter le reçu
                <svg class="w-3.5 h-3.5 ml-auto text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
            </a>

            {{-- Supprimer (seulement si pending) --}}
            @if(package.canDelete)
                <form method="POST" action="{{ route('backoffice.packages.destroy', { id: package.id }) }}"
                    x-data
                    @submit.prevent="if(confirm('Supprimer le colis {{ package.trackingNumber }} ? Cette action est irréversible.')) $el.submit()">
                    {{ csrfField() }}
                    <button type="submit"
                        class="w-full inline-flex items-center justify-center gap-2 rounded-xl border border-red-200 px-5 py-3 text-sm font-medium text-red-600 hover:bg-red-50 dark:border-red-800 dark:text-red-400 dark:hover:bg-red-900/20 transition-colors">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                        Supprimer ce colis
                    </button>
                </form>
            @end

        </div>

    </div>

</div>

@end
