<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reçu de dépôt — {{ pkg.trackingNumber }} — Wapika</title>
</head>
<body style="margin:0;padding:0;background-color:#f0f2f5;font-family:Arial,Helvetica,sans-serif;-webkit-font-smoothing:antialiased;">

  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
    <tr>
      <td style="padding:40px 16px;">

        <table role="presentation" width="600" cellspacing="0" cellpadding="0" border="0"
               style="max-width:600px;margin:0 auto;background-color:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,0.08);">

          {{-- Header --}}
          <tr>
            <td style="background-color:#2b2b63;padding:28px 40px;">
              <p style="margin:0;color:#ffffff;font-size:22px;font-weight:800;letter-spacing:0.3px;">Wapika</p>
              <p style="margin:6px 0 0;color:rgba(255,255,255,0.5);font-size:12px;letter-spacing:0.3px;">
                Confirmation d'enregistrement de colis
              </p>
            </td>
          </tr>

          {{-- Bande amber --}}
          <tr>
            <td style="background-color:#ed8b31;height:4px;font-size:0;line-height:0;">&nbsp;</td>
          </tr>

          {{-- Numéro de suivi --}}
          <tr>
            <td style="background-color:#f0f3ff;border-bottom:1px solid #dde9ff;padding:20px 40px;text-align:center;">
              <p style="margin:0 0 6px;font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#667085;">
                Numéro de suivi
              </p>
              <p style="margin:0;font-family:'Courier New',monospace;font-size:26px;font-weight:700;color:#d27318;letter-spacing:3px;">
                {{ pkg.trackingNumber }}
              </p>
            </td>
          </tr>

          {{-- Corps --}}
          <tr>
            <td style="padding:36px 40px 28px;">

              <p style="margin:0 0 20px;font-size:15px;color:#374151;line-height:1.6;">
                Bonjour <strong>{{ pkg.client.firstName }} {{ pkg.client.lastName }}</strong>,
              </p>
              <p style="margin:0 0 28px;font-size:14px;color:#6b7280;line-height:1.6;">
                Votre colis a bien été enregistré dans notre système. Voici le récapitulatif :
              </p>

              {{-- Détails --}}
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                     style="background-color:#f8fafc;border:1px solid #e9edf2;border-radius:8px;overflow:hidden;margin:0 0 28px;">
                <tr>
                  <td style="padding:6px 20px 0;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#9ca3af;">
                    Détails du colis
                  </td>
                </tr>
                <tr>
                  <td style="padding:12px 20px;border-bottom:1px solid #f2f4f7;">
                    <table width="100%" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td style="font-size:14px;color:#6b7280;">Désignation</td>
                        <td style="font-size:14px;color:#111827;font-weight:500;text-align:right;">{{ pkg.designation }}</td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding:12px 20px;border-bottom:1px solid #f2f4f7;">
                    <table width="100%" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td style="font-size:14px;color:#6b7280;">Poids</td>
                        <td style="font-size:14px;color:#111827;font-weight:500;text-align:right;">{{ pkg.weight }} kg</td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding:12px 20px;border-bottom:1px solid #f2f4f7;">
                    <table width="100%" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td style="font-size:14px;color:#6b7280;">Frais de livraison</td>
                        <td style="font-size:14px;color:#111827;font-weight:500;text-align:right;">{{ pkg.price.toLocaleString('fr-FR') }} KMF</td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding:12px 20px;">
                    <table width="100%" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td style="font-size:14px;color:#6b7280;">Livraison prévue</td>
                        <td style="font-size:14px;color:#111827;font-weight:500;text-align:right;">{{ pkg.estimatedDeliveryDate.setLocale('fr').toFormat('dd MMM yyyy') }}</td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              {{-- CTA --}}
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 auto 20px;">
                <tr>
                  <td style="border-radius:8px;background-color:#ed8b31;">
                    <a href="{{ receiptUrl }}"
                       style="display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;border-radius:8px;line-height:1;">
                      Consulter mon reçu
                    </a>
                  </td>
                </tr>
              </table>

              <p style="margin:0;font-size:12px;color:#9ca3af;text-align:center;line-height:1.6;">
                Ou copiez ce lien dans votre navigateur :<br>
                <a href="{{ receiptUrl }}" style="color:#ed8b31;word-break:break-all;">{{ receiptUrl }}</a>
              </p>

            </td>
          </tr>

          {{-- Séparateur --}}
          <tr>
            <td style="padding:0 40px;">
              <hr style="border:none;border-top:1px solid #f2f4f7;margin:0;">
            </td>
          </tr>

          {{-- Footer --}}
          <tr>
            <td style="padding:24px 40px;text-align:center;">
              <p style="margin:0 0 4px;font-size:12px;color:#9ca3af;line-height:1.6;">
                Vous recevez cet e-mail car un colis a été enregistré à votre nom.
              </p>
              <p style="margin:0;font-size:12px;color:#d1d5db;">
                © {{ new Date().getFullYear() }} Wapika — Agence de livraison
              </p>
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>
